<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:i="https://github.com/projektanker/icons.avalonia"
             xmlns:vm="using:MiComanderaApp.ViewModels"
             xmlns:vmTables="using:MiComanderaApp.ViewModels.Components"
             xmlns:views="using:MiComanderaApp.Views.Components"
             xmlns:models="using:MiComanderaApp.Models"
             mc:Ignorable="d" d:DesignWidth="1024" d:DesignHeight="768"
             x:Class="MiComanderaApp.Views.TablesView"
             x:DataType="vm:TablesViewModel"
             Background="{StaticResource FondoPrincipal}"
             FontFamily="Segoe UI, Roboto, sans-serif">



    <UserControl.DataTemplates>
        <DataTemplate DataType="{x:Type vmTables:AllTablesComponentViewModel}">
            <views:AllTablesComponent />
        </DataTemplate>

        <DataTemplate DataType="{x:Type vmTables:ActiveTablesComponentViewModel}">
            <views:ActiveTablesComponent />
        </DataTemplate>
    </UserControl.DataTemplates>


    <!-- ================= DISTRIBUCIÓN PRINCIPAL ================= -->
    <Grid ColumnDefinitions="*, 280">

        <!-- Panel Izquierdo: Catálogo de Mesas -->
        <DockPanel Grid.Column="0" Margin="1,1">
            <Grid DockPanel.Dock="Top"
                  Margin="8"
                  ColumnDefinitions="*,280">

                <!-- Izquierda -->
                <StackPanel Grid.Column="0" Spacing="4">
                    <TextBlock Text="{Binding ViewTitle}"
                               FontSize="26"
                               FontWeight="Bold"
                               Foreground="{DynamicResource TextoColor}" />

                    <TextBlock Text="Selecciona una mesa para gestionar pedidos"
                               FontSize="13"
                               Foreground="{DynamicResource TextoColor}" />
                </StackPanel>


                <StackPanel Grid.Column="1" Spacing="2" >

                    <TextBlock Text="{Binding User.NombreCompleto}"
                               FontWeight="Bold"
                               FontSize="16"
                               Foreground="{DynamicResource TextoBrush}"
                               HorizontalAlignment="Right"
                               VerticalAlignment="Center"/>

                    <TextBlock Text="{Binding User.Rol}"
                               FontSize="14"
                               Foreground="{DynamicResource TextoBrush}"
                               HorizontalAlignment="Right"
                               VerticalAlignment="Center"/>

                </StackPanel>
            </Grid>

            <Grid RowDefinitions="Auto, *">
                <ContentControl Grid.Row="1" Content="{Binding VistaActual}" />
            </Grid>
        </DockPanel>


        <!-- Panel Derecho: Menú Lateral -->
        <Border Grid.Column="1"
                Background="{StaticResource PosSurface}"
                BorderBrush="#6079A2"
                BorderThickness="1,0,0,0">

            <Grid RowDefinitions="Auto, *, Auto" Margin="20,24,20,20">

                <StackPanel Grid.Row="0" Spacing="12">
                    <TextBlock Text="Panel de Control"
                               FontSize="18"
                               FontWeight="Bold"
                               Foreground="#1A202C"
                               Margin="0,0,0,8" />

                    <TextBlock Text="ACCIONES"
                               FontSize="10"
                               FontWeight="Bold"
                               Foreground="{StaticResource PosGrayText}"
                               LetterSpacing="1.5" />

                    <!-- Nueva Orden -->
                    <Button HorizontalAlignment="Stretch"
                            Classes="btn-azul"
                            Command="{Binding AbirNuevaOrdenCommand}"
                            Height="48">
                        <StackPanel Orientation="Horizontal"
                                    HorizontalAlignment="Center"
                                    Spacing="10">
                            <i:Icon Value="fa-solid fa-file-circle-plus"
                                    Width="16"
                                    Height="16"
                                    />
                            <!-- Foreground="#1A202C" -->

                            <TextBlock Text="Nueva Orden"
                                       FontSize="14"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <!-- Unir Mesas -->
                    <Button HorizontalAlignment="Stretch"
                            Classes="btn-gris"
                            Height="44">
                        <StackPanel Orientation="Horizontal"
                                    HorizontalAlignment="Center"
                                    Spacing="10">
                            <i:Icon Value="fa-solid fa-arrows-to-circle"
                                    Width="16"
                                    Height="16"/>
                            <TextBlock Text="Unir Mesas"
                                       FontSize="13"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <!-- Transferir Cuenta -->
                    <Button HorizontalAlignment="Stretch"
                            Classes="btn-gris"
                            Height="44">
                        <StackPanel Orientation="Horizontal"
                                    HorizontalAlignment="Center"
                                    Spacing="10">
                            <i:Icon Value="fa-solid fa-rotate"
                                    Width="16"
                                    Height="16"
                                    />
                            <!-- Foreground="#1A202C" -->
                            <TextBlock Text="Transferir Cuenta"
                                       FontSize="13"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Border Height="1" Background="#E8EAED" Margin="0,8"/>

                    <TextBlock Text="FILTROS"
                               FontSize="10"
                               FontWeight="Bold"
                               Foreground="{StaticResource PosGrayText}"
                               LetterSpacing="1.5" />

                    <!-- Todas las Mesas -->
                    <Button HorizontalAlignment="Stretch"
                            Classes="btn-verde"
                            Height="44"
                            Command="{Binding ToggleTablesViewCommand}">
                        <StackPanel Orientation="Horizontal"
                                    HorizontalAlignment="Center"
                                    Spacing="10">
                            <i:Icon Value="fa-solid fa-table-cells"
                                    Width="16"
                                    Height="16"/>
                            <TextBlock Text="{Binding ToggleButtonText}"
                                       FontSize="13"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>

                <!-- Herramientas inferiores -->
                <StackPanel Grid.Row="1"
                            VerticalAlignment="Bottom"
                            Spacing="12">

                    <Border Height="1" Background="#E8EAED"/>

                    <TextBlock Text="HERRAMIENTAS"
                               FontSize="10"
                               FontWeight="Bold"
                               Foreground="{StaticResource PosGrayText}"
                               LetterSpacing="1.5" />

                    <!-- Corte de Caja -->
                    <Button HorizontalAlignment="Stretch"
                            Classes="btn-gris"
                            Height="44">
                        <StackPanel Orientation="Horizontal"
                                    HorizontalAlignment="Center"
                                    Spacing="10">
                            <i:Icon Value="fa-solid fa-object-group"
                                    Width="16"
                                    Height="16"/>

                            <TextBlock Text="Corte de Caja"
                                       FontSize="13"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button HorizontalAlignment="Stretch"
                            Classes="btn-gris"
                            IsVisible="{Binding Administrar}"
                            Height="44"
                            Command="{Binding IrAdministrarCommand}">
                        <StackPanel Orientation="Horizontal"
                                    HorizontalAlignment="Center"
                                    Spacing="10">
                            <i:Icon Value="fa-solid fa-object-group"
                                    Width="16"
                                    Height="16"/>

                            <TextBlock Text="Administrar"
                                       FontSize="13"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <!-- Reportes -->
                    <Button HorizontalAlignment="Stretch"
                            Classes="btn-gris"
                            Height="44">
                        <StackPanel Orientation="Horizontal"
                                    HorizontalAlignment="Center"
                                    Spacing="10">
                            <i:Icon Value="fa-solid fa-file-arrow-down"
                                    Width="16"
                                    Height="16"/>

                            <TextBlock Text="Reportes X/Z"
                                       FontSize="13"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>

                <!-- Salir -->
                <StackPanel Grid.Row="2" Margin="0,16,0,0">
                    <Border Height="2" Background="#E8EAED" Margin="0,0,0,12"/>

                    <Button HorizontalAlignment="Stretch"
                            Classes="btn-rojo"
                            Height="48"
                            Command="{Binding SalirCommand}">
                        <StackPanel Orientation="Horizontal"
                                    HorizontalAlignment="Center"
                                    Spacing="10">
                            <i:Icon Value="fa-solid fa-reply-all"
                                    Width="16"
                                    Height="16"/>
                            <TextBlock Text="Salir del Sistema"
                                       FontSize="14"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>

            </Grid>
        </Border>
    </Grid>
</UserControl>