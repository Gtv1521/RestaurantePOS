<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             xmlns:i="https://github.com/projektanker/icons.avalonia"
             xmlns:vm="using:MiComanderaApp.ViewModels.Orders"
             x:DataType="vm:CantidadPaxViewModel"
             x:Class="MiComanderaApp.Views.Orders.CantidadPaxView"
             Background="#F4F5F8"
             FontFamily="Courier New, JetBrains Mono, monospace">

  <Grid ColumnDefinitions="*, *">

    <!-- Panel Izquierdo: Controles -->
    <Grid Grid.Column="0" RowDefinitions="Auto, *, Auto" Width="280"
          HorizontalAlignment="Center" VerticalAlignment="Center">

      <!-- Título y Número de Mesa -->
      <StackPanel Grid.Row="0" Margin="0,20,0,10" HorizontalAlignment="Center">
        <TextBlock Text="{Binding Mesa, StringFormat='MESA N° {0}'}"
                   FontSize="28" FontWeight="Bold" Foreground="#272626"
                   HorizontalAlignment="Center"/>
        <TextBlock Text="CANTIDAD DE PERSONAS"
                   FontSize="16" Foreground="#242121"
                   HorizontalAlignment="Center" Margin="0,5,0,0"/>
      </StackPanel>

      <!-- Display de Cantidad y Teclado -->
      <StackPanel Grid.Row="1" VerticalAlignment="Center" Spacing="20">
        <!-- Display -->
        <Border Background="#E8E2E2" CornerRadius="8" Padding="10" MinHeight="60">
          <TextBlock Text="{Binding CantidadPax, FallbackValue='0'}"
                     FontSize="48" FontWeight="SemiBold" Foreground="#504848"
                     HorizontalAlignment="Center" VerticalAlignment="Center"/>
        </Border>

        <!-- Teclado Numérico -->
        <Grid Width="280" Height="320" ColumnDefinitions="*,*,*" RowDefinitions="*,*,*,*" RowSpacing="12" ColumnSpacing="12">
          <!-- Fila 1 -->
          <Button Grid.Row="0" Grid.Column="0" Content="1" Command="{Binding AddDigitCommand}" CommandParameter="1" Classes="Teclado"/>
          <Button Grid.Row="0" Grid.Column="1" Content="2" Command="{Binding AddDigitCommand}" CommandParameter="2" Classes="Teclado"/>
          <Button Grid.Row="0" Grid.Column="2" Content="3" Command="{Binding AddDigitCommand}" CommandParameter="3" Classes="Teclado"/>

          <!-- Fila 2 -->
          <Button Grid.Row="1" Grid.Column="0" Content="4" Command="{Binding AddDigitCommand}" CommandParameter="4" Classes="Teclado"/>
          <Button Grid.Row="1" Grid.Column="1" Content="5" Command="{Binding AddDigitCommand}" CommandParameter="5" Classes="Teclado"/>
          <Button Grid.Row="1" Grid.Column="2" Content="6" Command="{Binding AddDigitCommand}" CommandParameter="6" Classes="Teclado"/>

          <!-- Fila 3 -->
          <Button Grid.Row="2" Grid.Column="0" Content="7" Command="{Binding AddDigitCommand}" CommandParameter="7" Classes="Teclado"/>
          <Button Grid.Row="2" Grid.Column="1" Content="8" Command="{Binding AddDigitCommand}" CommandParameter="8" Classes="Teclado"/>
          <Button Grid.Row="2" Grid.Column="2" Content="9" Command="{Binding AddDigitCommand}" CommandParameter="9" Classes="Teclado"/>

          <!-- Fila 4 -->
          <Button Grid.Row="3" Grid.Column="1" Content="0" Command="{Binding AddDigitCommand}" CommandParameter="0" Classes="Teclado"/>
          <Button Grid.Row="3" Grid.Column="2" Command="{Binding DeleteDigitCommand}" Classes="Teclado" i:Attached.Icon="fa-solid fa-delete-left"/>
        </Grid>
      </StackPanel>

      <!-- Botones de Acción -->
      <Grid Grid.Row="2" ColumnDefinitions="*,*" ColumnSpacing="10" Margin="20">
        <Button Grid.Column="0" Content="CANCELAR"
                Command="{Binding CancelarCommand}"
                Background="#3c3c3c"
                Foreground="White"
                Height="50"
                FontSize="16"
                HorizontalContentAlignment="Center"
                VerticalContentAlignment="Center"
                FontWeight="Bold"
                CornerRadius="5"/>

        <Button Grid.Column="1" Content="ACEPTAR" IsEnabled="{Binding CantidadPax.Length}"
                Command="{Binding AceptarCommand}"
                Background="#4CAF50"
                Foreground="White"
                VerticalAlignment="Center"
                HorizontalAlignment="Center"
                VerticalContentAlignment="Center"
                HorizontalContentAlignment="Center"
                Height="50"
                FontSize="16"
                FontWeight="Bold"
                CornerRadius="14"/>
      </Grid>
    </Grid>

    <!-- Panel Derecho: Icono -->
    <Panel Grid.Column="1" Background="#DCCCCC">
      <i:Icon Value="fa-solid fa-utensils" FontSize="200" Foreground="#362D42"
              HorizontalAlignment="Center" VerticalAlignment="Center" />
    </Panel>
  </Grid>

  <UserControl.Styles>
    <Style Selector="Button.Teclado">
      <Setter Property="Background" Value="#D8DBE1"/>
      <Setter Property="Foreground" Value="#4A5568"/>
      <Setter Property="FontSize" Value="22"/>
      <Setter Property="HorizontalAlignment" Value="Stretch"/>
      <Setter Property="VerticalAlignment" Value="Stretch"/>
      <Setter Property="HorizontalContentAlignment" Value="Center"/>
      <Setter Property="VerticalContentAlignment" Value="Center"/>
      <Setter Property="CornerRadius" Value="14"/>
      <Setter Property="Transitions">
        <Transitions>
          <BrushTransition Property="Background" Duration="0:0:0.12"/>
        </Transitions>
      </Setter>
    </Style>
    <Style Selector="Button.Teclado:pointerover /template/ ContentPresenter">
      <Setter Property="Background" Value="#D2D6DC"/>
      <Setter Property="TextBlock.Foreground" Value="#1A202C"/>
    </Style>
  </UserControl.Styles>
</UserControl>
