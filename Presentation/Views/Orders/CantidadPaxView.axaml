<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             xmlns:i="https://github.com/projektanker/icons.avalonia"
             xmlns:vm="using:MiComanderaApp.ViewModels.Orders"
             x:DataType="vm:CantidadPaxViewModel"
             x:Class="MiComanderaApp.Views.Orders.CantidadPaxView"
             Background="{DynamicResource FondoPrincipal}"
             FontFamily="Courier New, JetBrains Mono, monospace">

  <Grid ColumnDefinitions="*, *">

    <!-- Panel Izquierdo: Controles -->
    <Grid Grid.Column="0" RowDefinitions="Auto, *, Auto" Width="280"
          HorizontalAlignment="Center" VerticalAlignment="Center">

      <!-- Título y Número de Mesa -->
      <StackPanel Grid.Row="0" Margin="0,20,0,10" HorizontalAlignment="Center">
        <TextBlock Text="{Binding Mesa, StringFormat='MESA N° {0}'}" IsVisible="{Binding NewMesa}"
                   FontSize="28" FontWeight="Bold" Foreground="{DynamicResource TextoBrush}"
                   HorizontalAlignment="Center"/>
        <TextBlock Text="{Binding Title}"
                   FontSize="16" Foreground="{DynamicResource TextoBrush}"
                   HorizontalAlignment="Center" Margin="0,5,0,0"/>
      </StackPanel>

      <!-- Display de Cantidad y Teclado -->
      <StackPanel Grid.Row="1" VerticalAlignment="Center" Spacing="20">
        <!-- Display -->
        <Border Background="#51E8E2E2" CornerRadius="8" Padding="10" Width="300" MinHeight="60">
          <TextBlock Text="{Binding CantidadPax, FallbackValue='0'}"
                     FontSize="48" FontWeight="SemiBold" Foreground="{DynamicResource TextoBrush}"
                     HorizontalAlignment="Center" VerticalAlignment="Center"/>
        </Border>

        <!-- Teclado Numérico -->
        <Grid Width="300" Height="400" ColumnDefinitions="*,*,*" RowDefinitions="*,*,*,*,*" RowSpacing="12" ColumnSpacing="12">
          <!-- Fila 1 -->
          <Button Grid.Row="0" Grid.Column="0" Content="1" Command="{Binding AddDigitCommand}" CommandParameter="1" Classes="KeypadBtn"/>
          <Button Grid.Row="0" Grid.Column="1" Content="2" Command="{Binding AddDigitCommand}" CommandParameter="2" Classes="KeypadBtn"/>
          <Button Grid.Row="0" Grid.Column="2" Content="3" Command="{Binding AddDigitCommand}" CommandParameter="3" Classes="KeypadBtn"/>

          <!-- Fila 2 -->
          <Button Grid.Row="1" Grid.Column="0" Content="4" Command="{Binding AddDigitCommand}" CommandParameter="4" Classes="KeypadBtn"/>
          <Button Grid.Row="1" Grid.Column="1" Content="5" Command="{Binding AddDigitCommand}" CommandParameter="5" Classes="KeypadBtn"/>
          <Button Grid.Row="1" Grid.Column="2" Content="6" Command="{Binding AddDigitCommand}" CommandParameter="6" Classes="KeypadBtn"/>

          <!-- Fila 3 -->
          <Button Grid.Row="2" Grid.Column="0" Content="7" Command="{Binding AddDigitCommand}" CommandParameter="7" Classes="KeypadBtn"/>
          <Button Grid.Row="2" Grid.Column="1" Content="8" Command="{Binding AddDigitCommand}" CommandParameter="8" Classes="KeypadBtn"/>
          <Button Grid.Row="2" Grid.Column="2" Content="9" Command="{Binding AddDigitCommand}" CommandParameter="9" Classes="KeypadBtn"/>

          <!-- Fila 4 -->
          <Button Grid.Row="3" Grid.Column="0" Content=" " Classes="KeypadBtn"/>
          <Button Grid.Row="3" Grid.Column="1" Content="0" Command="{Binding AddDigitCommand}" CommandParameter="0" Classes="KeypadBtn"/>
          <Button Grid.Row="3" Grid.Column="2" Command="{Binding DeleteDigitCommand}" Classes="KeypadBtn" i:Attached.Icon="fa-solid fa-delete-left"/>

          <Grid Grid.Row="4"
                Grid.Column="0"
                Grid.ColumnSpan="3"
                ColumnDefinitions="*,*"
                ColumnSpacing="12">

            <Button Grid.Column="0"
                    Content="CANCELAR"
                    Command="{Binding CancelarCommand}"
                    Classes="KeypadBtn"
                    FontWeight="Bold"
                    Background="#3c3c3c"
                    Foreground="White"/>

            <Button Grid.Column="1"
                    Content="ACEPTAR"
                    Classes="KeypadBtn"
                    FontWeight="Bold"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch"
                    Command="{Binding AceptarCommand}"
                    Background="#4CAF50"
                    Foreground="Black"/>

          </Grid>
        </Grid>
      </StackPanel>

    </Grid>

    <!-- Panel Derecho: Icono -->
    <Panel Grid.Column="1" Background="#78DCCCCC">
      <i:Icon Value="fa-solid fa-utensils" FontSize="200" Foreground="#362D42"
              HorizontalAlignment="Center" VerticalAlignment="Center" />
    </Panel>
  </Grid>
</UserControl>
