<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:system="using:System"
                    xmlns:vm="using:MiComanderaApp.ViewModels"
                    xmlns:i="using:Projektanker.Icons.Avalonia"
                    xmlns:models="using:MiComanderaApp.Models"
                    xmlns:vmProduct="using:MiComanderaApp.ViewModels.Components.Admin"
                    >


    <DataTemplate x:Key="MesaTemplate" DataType="{x:Type vm:TableViewModel}">
        <Border Width="150"
                Height="130"
                Margin="10"
                CornerRadius="16"
                BorderBrush="#AE9D9D"
                BorderThickness="1"
                Background="{Binding Status}">

            <Button HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch"
                    BorderThickness="0"
                    CornerRadius="16"
                    Padding="0"
                    Background="Transparent"
                    Cursor="Hand"
                    Command="{Binding OpenTableCommand}">

                <Button.Styles>
                    <Style Selector="Button:pointerover /template/ ContentPresenter#PART_ContentPresenter">
                        <Setter Property="Background" Value="#69634965" />
                    </Style>
                    <Style Selector="Button:pressed /template/ ContentPresenter#PART_ContentPresenter">
                        <Setter Property="Background" Value="#0F000000" />
                    </Style>
                </Button.Styles>

                <Grid RowDefinitions="Auto,*">
                    <Border Grid.Row="0" Height="4" CornerRadius="2" Margin="20,8,20,0" Background="#34A853"/>

                    <StackPanel Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="2">
                        <TextBlock Text="MESA" HorizontalAlignment="Center" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource PosGrayText}" Opacity="0.6" LetterSpacing="2.5" />
                        <TextBlock Text="{Binding TableNumber}" HorizontalAlignment="Center" FontSize="38" FontWeight="Bold" Foreground="#1A202C" />
                    </StackPanel>
                </Grid>
            </Button>
        </Border>
    </DataTemplate>

    <DataTemplate x:Key="AllMesaTemplate" DataType="{x:Type vm:TableViewModel}">
        <Border Width="90" Height="90" Margin="4" CornerRadius="12" BorderThickness="1" BorderBrush="{Binding ColorEstado}">
            
            <Border.Tag>
                <Binding Path="Status" />
            </Border.Tag>

            <Border.Styles>
                <Style Selector="Border[Tag=Libre]"><Setter Property="Background" Value="#34AA55" /></Style>
                <Style Selector="Border[Tag=Ocupada]"><Setter Property="Background" Value="#2B6CB0" /></Style>
                <Style Selector="Border[Tag=Disponible]"><Setter Property="Background" Value="#ED8936" /></Style>
            </Border.Styles>
                
            <Button HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch"
                    BorderThickness="0"
                    CornerRadius="12"
                    Padding="0"
                    Background="{Binding ColorEstado}"
                    Cursor="Hand"
                    Command="{Binding OpenTableCommand}"> 

                <Button.Styles>
                    <Style Selector="Button:pointerover /template/ ContentPresenter#PART_ContentPresenter">
                        <Setter Property="Background" Value="Transparent" />
                    </Style>
                    <Style Selector="Button:pressed /template/ ContentPresenter#PART_ContentPresenter">
                        <Setter Property="Background" Value="#B05B5463" />
                    </Style>
                </Button.Styles>

                <Grid RowDefinitions="*,*,Auto">
                    <StackPanel Grid.Row="0" VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="1">
                        <TextBlock Text="{Binding TableNumber}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   FontSize="30"
                                   FontWeight="Black"
                                   Foreground="{DynamicResource TextoColor}" />
                    </StackPanel>
                    <StackPanel Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="1">
                  
                        <TextBlock HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   FontSize="13"
                                   IsVisible="{Binding Pax}"
                                   Foreground="{DynamicResource TextoColor}"> 

                            <Run Text="Pax: "/>
                            <Run Text="{Binding Table.Capacidad}"/>
                        </TextBlock>

                    </StackPanel>
                    <StackPanel Grid.Row="2" 
                                    Orientation="Horizontal" 
                                    HorizontalAlignment="Center"
                                    Spacing="8">
                            <Button Classes="MesaActionButton"
                                    Content="📝"
                                    IsEnabled="{Binding Open}"
                                    />
                            <Button Classes="MesaActionButton"
                                    i:Attached.Icon="fa-solid fa-plus"
                                    FontWeight="Black"
                                    Foreground="Blue"
                                    IsEnabled="{Binding Vacio}"
                                    />
                        </StackPanel>
                </Grid>
            </Button>
        </Border>
    </DataTemplate>

    <DataTemplate x:Key="ShowProducts" DataType="{x:Type models:ProductoModel}">
    <Border Background="{DynamicResource FondoTarjeta}" Width="300" MaxHeight="260" CornerRadius="12" ClipToBounds="True" Margin="5" >
        <Grid RowDefinitions="110,*">
            
            <Grid Grid.Row="0">
                <Image Source="{Binding ImageUrl}" Stretch="UniformToFill"/>
                
                <Border Background="#15000000"/>

                <Border Background="{DynamicResource Estadistica}" 
                        CornerRadius="4" 
                        HorizontalAlignment="Left" 
                        VerticalAlignment="Top" 
                        Margin="12" 
                        Padding="8,4">
                    <TextBlock Text="{Binding CategoryName}" Foreground="{DynamicResource TextoColor}" FontSize="13" FontWeight="Bold"/>
                </Border>

                <Border Background="{DynamicResource NumBotton}" 
                        CornerRadius="4" 
                        HorizontalAlignment="Right" 
                        VerticalAlignment="Top" 
                        Margin="12" 
                        Padding="6,4">
                    <TextBlock Text="{Binding IsAvailable}" Foreground="{DynamicResource TextoColor}" FontSize="11" FontWeight="Bold"/>
                </Border>
            </Grid>

            <Border Grid.Row="1" Padding="15,12" Grid.RowSpan="2">
                <Grid RowDefinitions="Auto,Auto,Auto">
                    
                    <TextBlock Grid.Row="0" 
                               Text="{Binding Name}" 
                               Foreground="{DynamicResource TextoColor}" 
                               FontSize="15" 
                               FontWeight="SemiBold" 
                               />
                               <!-- TextTrimming="CharacterEllipsis" -->

                    <Grid Grid.Row="1" ColumnDefinitions="*,Auto" Margin="0,1,0,10">
                        <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="4">
                            <TextBlock Text="S/" Foreground="{DynamicResource Estadistica}" FontSize="15" FontWeight="Bold" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding Price, StringFormat='{}{0:N2}'}" Foreground="{DynamicResource Estadistica}" FontSize="16" FontWeight="Bold" VerticalAlignment="Center"/>
                        </StackPanel>
                        
                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                            <TextBlock Text="{Binding TaxPercentage, StringFormat='{}IVA {0}%'}" Foreground="#4F5E67" FontSize="11"/>
                            <StackPanel Orientation="Horizontal" Spacing="4">
                                <i:Icon Value="fa-solid fa-print" Foreground="{DynamicResource TextoColor}" FontSize="11"/>
                                <TextBlock Text="{Binding Description}" Foreground="#4F5E67" FontSize="11"/>
                            </StackPanel>
                        </StackPanel>
                    </Grid>

                    <Grid Grid.Row="2" ColumnDefinitions="*,Auto" ColumnSpacing="10">
                        <Button Grid.Column="0" 
                                Background="{DynamicResource BorderEditar}" 
                                Height="32"
                                HorizontalAlignment="Stretch" 
                                HorizontalContentAlignment="Center" 
                                VerticalContentAlignment="Center"
                                CornerRadius="6">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <i:Icon Value="fa-solid fa-pen" Foreground="{DynamicResource BotonText}" FontSize="12"/>
                                <TextBlock Text="Editar" Foreground="{DynamicResource BotonText}" FontSize="13" FontWeight="SemiBold"/>
                            </StackPanel>
                        </Button>

                        <Button Grid.Column="1" 
                                Background="{DynamicResource BotonDelete}" 
                                Width="35" Height="32"
                                HorizontalContentAlignment="Center" 
                                VerticalContentAlignment="Center"
                                CornerRadius="6">
                            <i:Icon Value="fa-solid fa-trash" Foreground="#c91815" FontSize="12"/>
                        </Button>
                    </Grid> 
                </Grid>
            </Border>
        </Grid>
    </Border>
</DataTemplate>

    <DataTemplate x:Key="Tables" DataType="{x:Type vm:TableViewModel}">

                <!-- TARJETA DE MESA -->
                <Button Classes="MesaCard"
                    Background="{Binding ColorEstado}"
                    Margin="3,3"
                    MinWidth="170"
                    CornerRadius="18"
                    HorizontalAlignment="Stretch"
                    Command="{Binding OpenTableCommand}"
                    Classes.ocupada="{Binding ClaseEstado}"        
                    Tag="{Binding}">
                    
                    <Grid RowDefinitions="Auto,*,Auto">
                        
                        <!-- Número -->
                        <TextBlock Grid.Row="0" 
                                   Text="{Binding TableNumber}"
                                   Foreground="{DynamicResource TextoColor}" 
                                   Classes="MesaNumero"/>
                        
                        <!-- Información -->
                        <StackPanel Grid.Row="1" 
                                    Spacing="2"
                                    VerticalAlignment="Center">
                            <TextBlock Text="{Binding Table.Capacidad}"
                                        Foreground="{DynamicResource TextoColor}" 
                                       Classes="MesaEstado"/>
                            <TextBlock Text="{Binding Table.Estado}" 
                                       Foreground="{DynamicResource TextoColor}" 
                                       Classes="MesaCliente"
                                       IsVisible="True"/>
                            <TextBlock Text="TiempoEspera" 
                                       Foreground="{DynamicResource TextoColor}" 
                                       Classes="MesaTiempo"
                                       IsVisible="True"/>
                        </StackPanel>
                        
                        <!-- Acciones -->
                        <StackPanel Grid.Row="2" 
                                    Orientation="Horizontal" 
                                    HorizontalAlignment="Center"
                                    Spacing="8">
                            <Button Classes="MesaActionButton"
                                    Content="📝"
                                    IsVisible="True"
                                    />
                            <Button Classes="MesaActionButton"
                                    Content="➕"
                                    IsVisible="True"
                                    />
                        </StackPanel>
                    </Grid>
                    
                </Button>
            </DataTemplate>


<DropShadowEffect x:Key="SombraSuave" 
    BlurRadius="6" 
    OffsetX="0" 
    OffsetY="2" 
    Opacity="0.08"/>
        
        <!-- Sombra media -->
<DropShadowEffect x:Key="SombraMedia" 
    BlurRadius="12" 
    OffsetX="0" 
    OffsetY="4" 
    Opacity="0.12"/>
        
        <!-- Sombra fuerte -->
<DropShadowEffect x:Key="SombraFuerte" 
    BlurRadius="20" 
    OffsetX="0" 
    OffsetY="8" 
    Opacity="0.2"/>
        
        <!-- Sombra de hover para tarjetas -->
<DropShadowEffect x:Key="SombraHover" 
    BlurRadius="16" 
    OffsetX="0" 
    OffsetY="6" 
    Opacity="0.25"/>
</ResourceDictionary>