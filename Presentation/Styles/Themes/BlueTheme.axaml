<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <SolidColorBrush x:Key="FondoPrincipal" Color="#04071B"/>
  <SolidColorBrush x:Key="FondoTarjeta" Color="#970E2A48"/>
  <SolidColorBrush x:Key="PanelName" Color="#2BA09EBC"/>
  <SolidColorBrush x:Key="Name" Color="#F6E2C013"/>

  <SolidColorBrush x:Key="TextoColor" Color="#DCE3E9"/>
  <SolidColorBrush x:Key="TextoBrush" Color="#D8DFE7"/>
  <SolidColorBrush x:Key="Resalto" Color="#98A2B3"/>
  <SolidColorBrush x:Key="Subtitle" Color="#E5EFA2"/>
  <SolidColorBrush x:Key="Estadistica" Color="#E37419"/>

  <!-- Teclado -->
  <SolidColorBrush x:Key="NumBotton" Color="#2BAFBFD0"/>
  <SolidColorBrush x:Key="SaveBotton" Color="#F7E1E7EC"/>

  <!-- Botones  -->
  <SolidColorBrush x:Key="BorderEditar" Color="#222B36"/> <!-- Boton de editar menu -->
  <SolidColorBrush x:Key="BotonDelete" Color="#932D2D30" />

  <SolidColorBrush x:Key="BotonCeleste" Color="#99C0F3"/>
  <SolidColorBrush x:Key="BotonGreen" Color="#D060BC65"/>
  <SolidColorBrush x:Key="BotonAdd" Color="#D060BC65" />

  <SolidColorBrush x:Key="BotonText" Color="#F7ECE7E7" />  <!-- texto de teclado de numeros -->
  <SolidColorBrush x:Key="TextBotton" Color="#FA060606"/>  <!-- texto de acciones de botones -->

  <SolidColorBrush x:Key="Border" Color="#D0687168"/>

  <SolidColorBrush x:Key="FondoPanelModal" Color="#5B36363A"/>
  <SolidColorBrush x:Key="FondoModal" Color="#1A0E26"/>
  <SolidColorBrush x:Key="BorderModal" Color="#615fb368"/>

</ResourceDictionary>
