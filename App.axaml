<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="MiComanderaApp.App"
             xmlns:local="using:MiComanderaApp.Services.Routing"
             RequestedThemeVariant="Light">
    
    <Application.DataTemplates>
        <local:ViewLocator />
    </Application.DataTemplates>

    <Application.Styles>
        <FluentTheme />
        
        <!-- Incluir los estilos y recursos del tema -->
        <StyleInclude Source="avares://MiComanderaApp/Styles/NaviTheme.axaml"/>
    </Application.Styles>
    
</Application>