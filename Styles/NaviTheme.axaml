<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Styles.Resources>
        <!-- ================= COLORES DEL TEMA ================= -->
        <!-- Fondo principal -->
        <SolidColorBrush x:Key="PosBackground" Color="#F0F2F5"/>
        <SolidColorBrush x:Key="PosSurface" Color="#FFFFFF"/>
        
        <!-- Azul - Acciones principales -->
        <SolidColorBrush x:Key="PosBlueText" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="PosBlueBg" Color="#2563EB"/>
        <SolidColorBrush x:Key="PosBlueHover" Color="#1D4ED8"/>
        <SolidColorBrush x:Key="PosBluePressed" Color="#1E40AF"/>

        <!-- Verde - Confirmaciones, mesas disponibles -->
        <SolidColorBrush x:Key="PosGreenText" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="PosGreenBg" Color="#059669"/>
        <SolidColorBrush x:Key="PosGreenHover" Color="#047857"/>
        <SolidColorBrush x:Key="PosGreenPressed" Color="#065F46"/>

        <!-- Rojo - Peligro, salir, mesas ocupadas -->
        <SolidColorBrush x:Key="PosRedText" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="PosRedBg" Color="#DC2626"/>
        <SolidColorBrush x:Key="PosRedHover" Color="#B91C1C"/>
        <SolidColorBrush x:Key="PosRedPressed" Color="#991B1B"/>

        <!-- Gris - Acciones secundarias -->
        <SolidColorBrush x:Key="PosGrayText" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="PosGrayBg" Color="#6B7280"/>
        <SolidColorBrush x:Key="PosGrayHover" Color="#4B5563"/>
        <SolidColorBrush x:Key="PosGrayPressed" Color="#374151"/>

        <!-- Naranja - Mesas con pedido pendiente -->
        <SolidColorBrush x:Key="PosOrangeText" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="PosOrangeBg" Color="#EA580C"/>
        <SolidColorBrush x:Key="PosOrangeHover" Color="#C2410C"/>
        <SolidColorBrush x:Key="PosOrangePressed" Color="#9A3412"/>

        <!-- Colores para estados de mesa -->
        <SolidColorBrush x:Key="MesaDisponible" Color="#10B981"/>
        <SolidColorBrush x:Key="MesaOcupada" Color="#EF4444"/>
        <SolidColorBrush x:Key="MesaPendiente" Color="#F59E0B"/>
        <SolidColorBrush x:Key="MesaReservada" Color="#6366F1"/>
    </Styles.Resources>

    <!-- ================= ESTILOS BASE ================= -->
    <Style Selector="Button.btn-azul, Button.btn-verde, Button.btn-rojo, Button.btn-gris, Button.btn-naranja">
        <Setter Property="HorizontalContentAlignment" Value="Center"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="CornerRadius" Value="12"/>
        <Setter Property="Height" Value="44"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="Padding" Value="16,0"/>
        <Setter Property="Cursor" Value="Hand"/>
    </Style>

    <!-- ================= BOTÓN AZUL ================= -->
    <Style Selector="Button.btn-azul">
        <Setter Property="Background" Value="{StaticResource PosBlueBg}"/>
        <Setter Property="Foreground" Value="{StaticResource PosBlueText}"/>
    </Style>
    <Style Selector="Button.btn-azul:pointerover">
        <Setter Property="Background" Value="{StaticResource PosBlueHover}"/>
    </Style>
    <Style Selector="Button.btn-azul:pressed">
        <Setter Property="Background" Value="{StaticResource PosBluePressed}"/>
    </Style>

    <!-- ================= BOTÓN VERDE ================= -->
    <Style Selector="Button.btn-verde">
        <Setter Property="Background" Value="{StaticResource PosGreenBg}"/>
        <Setter Property="Foreground" Value="{StaticResource PosGreenText}"/>
    </Style>
    <Style Selector="Button.btn-verde:pointerover">
        <Setter Property="Background" Value="{StaticResource PosGreenHover}"/>
    </Style>
    <Style Selector="Button.btn-verde:pressed">
        <Setter Property="Background" Value="{StaticResource PosGreenPressed}"/>
    </Style>

    <!-- ================= BOTÓN ROJO ================= -->
    <Style Selector="Button.btn-rojo">
        <Setter Property="Background" Value="{StaticResource PosRedBg}"/>
        <Setter Property="Foreground" Value="{StaticResource PosRedText}"/>
    </Style>
    <Style Selector="Button.btn-rojo:pointerover">
        <Setter Property="Background" Value="{StaticResource PosRedHover}"/>
    </Style>
    <Style Selector="Button.btn-rojo:pressed">
        <Setter Property="Background" Value="{StaticResource PosRedPressed}"/>
    </Style>

    <!-- ================= BOTÓN GRIS ================= -->
    <Style Selector="Button.btn-gris">
        <Setter Property="Background" Value="{StaticResource PosGrayBg}"/>
        <Setter Property="Foreground" Value="{StaticResource PosGrayText}"/>
    </Style>
    <Style Selector="Button.btn-gris:pointerover">
        <Setter Property="Background" Value="{StaticResource PosGrayHover}"/>
    </Style>
    <Style Selector="Button.btn-gris:pressed">
        <Setter Property="Background" Value="{StaticResource PosGrayPressed}"/>
    </Style>

    <!-- ================= BOTÓN NARANJA ================= -->
    <Style Selector="Button.btn-naranja">
        <Setter Property="Background" Value="{StaticResource PosOrangeBg}"/>
        <Setter Property="Foreground" Value="{StaticResource PosOrangeText}"/>
    </Style>
    <Style Selector="Button.btn-naranja:pointerover">
        <Setter Property="Background" Value="{StaticResource PosOrangeHover}"/>
    </Style>
    <Style Selector="Button.btn-naranja:pressed">
        <Setter Property="Background" Value="{StaticResource PosOrangePressed}"/>
    </Style>

</Styles>