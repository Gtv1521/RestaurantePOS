<UserControl xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="using:MiComanderaApp.ViewModels"
    xmlns:models="using:MiComanderaApp.Models"
    mc:Ignorable="d" d:DesignWidth="1024" d:DesignHeight="768"
    x:Class="MiComanderaApp.Views.TablesView"
    x:DataType="vm:TablesViewModel"
    Background="{StaticResource PosBackground}"
    FontFamily="Segoe UI, Roboto, sans-serif">

    <UserControl.Resources>
        <!-- ================= ICONOS SVG ================= -->
        <!-- Icono: Agregar/Nueva Orden -->
        <StreamGeometry x:Key="IconAdd">M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm5 11h-4v4h-2v-4H7v-2h4V7h2v4h4v2z</StreamGeometry>
        
        <!-- Icono: Unir/Merge -->
        <StreamGeometry x:Key="IconMerge">M17 20.41L18.41 19 15 15.59 13.59 17 17 20.41zM7.5 8H11v5.59L5.59 19 7 20.41l6-6V8h3.5L12 3.5 7.5 8z</StreamGeometry>
        
        <!-- Icono: Transferir/Swap -->
        <StreamGeometry x:Key="IconSwap">M6.99 11L3 15l3.99 4v-3H14v-2H6.99v-3zM21 9l-3.99-4v3H10v2h7.01v3L21 9z</StreamGeometry>
        
        <!-- Icono: Grid/Mesas -->
        <StreamGeometry x:Key="IconGrid">M4 8h4V4H4v4zm6 12h4v-4h-4v4zm-6 0h4v-4H4v4zm0-6h4v-4H4v4zm6 0h4v-4h-4v4zm6-10v4h4V4h-4zm-6 4h4V4h-4v4zm6 6h4v-4h-4v4zm0 6h4v-4h-4v4z</StreamGeometry>
        
        <!-- Icono: Dinero/Corte de Caja -->
        <StreamGeometry x:Key="IconMoney">M11.8 10.9c-2.27-.59-3-1.2-3-2.15 0-1.09 1.01-1.85 2.7-1.85 1.78 0 2.44.85 2.5 2.1h2.21c-.07-1.72-1.12-3.3-3.21-3.81V3h-3v2.16c-1.94.42-3.5 1.68-3.5 3.61 0 2.31 1.91 3.46 4.7 4.13 2.5.6 3 1.48 3 2.41 0 .69-.49 1.79-2.7 1.79-2.06 0-2.87-.92-2.98-2.1h-2.2c.12 2.19 1.76 3.42 3.68 3.83V21h3v-2.15c1.95-.37 3.5-1.5 3.5-3.55 0-2.84-2.43-3.81-4.7-4.4z</StreamGeometry>
        
        <!-- Icono: Reportes/Documento -->
        <StreamGeometry x:Key="IconReport">M14 2H6c-1.1 0-2 .9-2 2v16c0 1.1.9 2 2 2h12c1.1 0 2-.9 2-2V8l-6-6zM6 20V4h7v5h5v11H6zm2-6h8v2H8v-2zm0-4h8v2H8v-2z</StreamGeometry>
        
        <!-- Icono: Salir -->
        <StreamGeometry x:Key="IconExit">M10.09 15.59L11.5 17l5-5-5-5-1.41 1.41L12.67 11H3v2h9.67l-2.58 2.59zM19 3H5c-1.11 0-2 .9-2 2v4h2V5h14v14H5v-4H3v4c0 1.1.89 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2z</StreamGeometry>

        <!-- ================= TEMPLATE DE MESA ================= -->
        <DataTemplate x:Key="MesaTemplate" DataType="{x:Type vm:TableViewModel}">
            <Border Width="150"
                    Height="130"
                    Margin="10"
                    CornerRadius="16"
                    BorderBrush="#E0E0E0"
                    BorderThickness="1"
                    Background="{Binding Status, Converter={x:Static vm:TableViewModel.StatusToClassConverter}, FallbackValue=#E6F4EA}">
                
                <Button HorizontalAlignment="Stretch"
                        VerticalAlignment="Stretch"
                        BorderThickness="0"
                        CornerRadius="16"
                        Padding="0"
                        Background="Transparent"
                        Cursor="Hand">
                    
                    <Button.Styles>
                        <Style Selector="Button:pointerover /template/ ContentPresenter#PART_ContentPresenter">
                            <Setter Property="Background" Value="Transparent" />
                        </Style>
                        <Style Selector="Button:pressed /template/ ContentPresenter#PART_ContentPresenter">
                            <Setter Property="Background" Value="#0F000000" />
                        </Style>
                    </Button.Styles>

                    <Grid RowDefinitions="Auto,*">
                        <Border Grid.Row="0" 
                                Height="4" 
                                CornerRadius="2"
                                Margin="20,8,20,0"
                                Background="#34A853"/>
                        
                        <StackPanel Grid.Row="1" 
                                    VerticalAlignment="Center" 
                                    HorizontalAlignment="Center" 
                                    Spacing="2">
                            <TextBlock Text="MESA"
                                       HorizontalAlignment="Center"
                                       FontSize="11"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource PosGrayText}"
                                       Opacity="0.6"
                                       LetterSpacing="2.5" />
                            
                            <TextBlock Text="{Binding TableNumber}"
                                       HorizontalAlignment="Center"
                                       FontSize="38"
                                       FontWeight="Bold"
                                       Foreground="#1A202C" />
                        </StackPanel>
                    </Grid>
                </Button>
            </Border>
        </DataTemplate>
    </UserControl.Resources>

    <!-- ================= DISTRIBUCIÓN PRINCIPAL ================= -->
    <Grid ColumnDefinitions="*, 280">

        <!-- Panel Izquierdo: Catálogo de Mesas -->
        <DockPanel Grid.Column="0" Margin="24,20">
            
            <StackPanel DockPanel.Dock="Top" Margin="0,0,0,20" Spacing="4">
                <TextBlock Text="{Binding ViewTitle}"
                           FontSize="26"
                           FontWeight="Bold"
                           Foreground="#1A202C" />
                <TextBlock Text="Selecciona una mesa para gestionar pedidos"
                           FontSize="13"
                           Foreground="{StaticResource PosGrayText}" />
            </StackPanel>

            <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                          VerticalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{Binding Tables}"
                              ItemTemplate="{StaticResource MesaTemplate}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                </ItemsControl>
            </ScrollViewer>
        </DockPanel>

        <!-- Panel Derecho: Menú Lateral -->
        <Border Grid.Column="1" 
                Background="{StaticResource PosSurface}" 
                BorderBrush="#E8EAED" 
                BorderThickness="1,0,0,0">
            
            <Grid RowDefinitions="Auto, *, Auto" Margin="20,24,20,20">
                
                <StackPanel Grid.Row="0" Spacing="12">
                    <TextBlock Text="Panel de Control" 
                               FontSize="18" 
                               FontWeight="Bold"
                               Foreground="#1A202C"
                               Margin="0,0,0,8" />

                    <TextBlock Text="ACCIONES" 
                               FontSize="10" 
                               FontWeight="Bold"
                               Foreground="{StaticResource PosGrayText}" 
                               LetterSpacing="1.5" />
                    
                    <!-- Nueva Orden -->
                    <Button HorizontalAlignment="Stretch"
                            Classes="btn-azul" 
                            Command="{Binding AbirNuevaOrdenCommand}"
                            Height="48">
                        <StackPanel Orientation="Horizontal" 
                                    HorizontalAlignment="Center" 
                                    Spacing="10">
                            <PathIcon Data="{StaticResource IconAdd}" 
                                      Width="18" 
                                      Height="18"/>
                            <TextBlock Text="Nueva Orden" 
                                       FontSize="14"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    
                    <!-- Unir Mesas -->
                    <Button HorizontalAlignment="Stretch" 
                            Classes="btn-gris"
                            Height="44">
                        <StackPanel Orientation="Horizontal" 
                                    HorizontalAlignment="Center" 
                                    Spacing="10">
                            <PathIcon Data="{StaticResource IconMerge}" 
                                      Width="16" 
                                      Height="16"/>
                            <TextBlock Text="Unir Mesas" 
                                       FontSize="13"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    
                    <!-- Transferir Cuenta -->
                    <Button HorizontalAlignment="Stretch"
                            Classes="btn-gris"
                            Height="44">
                        <StackPanel Orientation="Horizontal" 
                                    HorizontalAlignment="Center" 
                                    Spacing="10">
                            <PathIcon Data="{StaticResource IconSwap}" 
                                      Width="16" 
                                      Height="16"/>
                            <TextBlock Text="Transferir Cuenta" 
                                       FontSize="13"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    
                    <Border Height="1" Background="#E8EAED" Margin="0,8"/>
                    
                    <TextBlock Text="FILTROS" 
                               FontSize="10" 
                               FontWeight="Bold"
                               Foreground="{StaticResource PosGrayText}" 
                               LetterSpacing="1.5" />
                    
                    <!-- Todas las Mesas -->
                    <Button HorizontalAlignment="Stretch"
                            Classes="btn-verde"
                            Height="44">
                        <StackPanel Orientation="Horizontal" 
                                    HorizontalAlignment="Center" 
                                    Spacing="10">
                            <PathIcon Data="{StaticResource IconGrid}" 
                                      Width="16" 
                                      Height="16"/>
                            <TextBlock Text="Todas las Mesas" 
                                       FontSize="13"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>

                <!-- Herramientas inferiores -->
                <StackPanel Grid.Row="1" 
                            VerticalAlignment="Bottom" 
                            Spacing="12">
                    
                    <Border Height="1" Background="#E8EAED"/>
                    
                    <TextBlock Text="HERRAMIENTAS" 
                               FontSize="10" 
                               FontWeight="Bold"
                               Foreground="{StaticResource PosGrayText}" 
                               LetterSpacing="1.5" />
                    
                    <!-- Corte de Caja -->
                    <Button HorizontalAlignment="Stretch"
                            Classes="btn-gris"
                            Height="44">
                        <StackPanel Orientation="Horizontal" 
                                    HorizontalAlignment="Center" 
                                    Spacing="10">
                            <PathIcon Data="{StaticResource IconMoney}" 
                                      Width="16" 
                                      Height="16"/>
                            <TextBlock Text="Corte de Caja" 
                                       FontSize="13"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    
                    <!-- Reportes -->
                    <Button HorizontalAlignment="Stretch" 
                            Classes="btn-gris"
                            Height="44">
                        <StackPanel Orientation="Horizontal" 
                                    HorizontalAlignment="Center" 
                                    Spacing="10">
                            <PathIcon Data="{StaticResource IconReport}" 
                                      Width="16" 
                                      Height="16"/>
                            <TextBlock Text="Reportes X/Z" 
                                       FontSize="13"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>

                <!-- Salir -->
                <StackPanel Grid.Row="2" Margin="0,16,0,0">
                    <Border Height="2" Background="#E8EAED" Margin="0,0,0,12"/>
                    
                    <Button HorizontalAlignment="Stretch"
                            Classes="btn-rojo"
                            Height="48"
                            Command="{Binding SalirCommand}">
                        <StackPanel Orientation="Horizontal" 
                                    HorizontalAlignment="Center" 
                                    Spacing="10">
                            <PathIcon Data="{StaticResource IconExit}" 
                                      Width="18" 
                                      Height="18"/>
                            <TextBlock Text="Salir del Sistema" 
                                       FontSize="14"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>

            </Grid>
        </Border>
    </Grid>
</UserControl>