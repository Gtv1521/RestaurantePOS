<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:MiComanderaApp.ViewModels"
             mc:Ignorable="d" d:DesignWidth="1024" d:DesignHeight="600"
             x:Class="MiComanderaApp.Views.LoginView"
             x:DataType="vm:LoginViewModel"
             Background="#F4F5F8"
             FontFamily="Courier New, JetBrains Mono, monospace">

    <Design.DataContext>
        <vm:LoginViewModel/>
    </Design.DataContext>

    <UserControl.Styles>
        <Style Selector="Button.KeypadBtn">
            <Setter Property="Background" Value="#E4E7ED"/>
            <Setter Property="Foreground" Value="#4A5568"/>
            <Setter Property="FontSize" Value="22"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="VerticalAlignment" Value="Stretch"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="CornerRadius" Value="14"/>
            <Setter Property="Transitions">
                <Transitions>
                    <BrushTransition Property="Background" Duration="0:0:0.12"/>
                </Transitions>
            </Setter>
        </Style>
        
        <Style Selector="Button.KeypadBtn:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#D2D6DC"/>
            <Setter Property="TextBlock.Foreground" Value="#1A202C"/>
        </Style>
    </UserControl.Styles>

    <Grid ColumnDefinitions="*, *">
        
        <Grid Grid.Column="0" RowDefinitions="Auto, *, Auto" Margin="50,60">
            
            <StackPanel Grid.Row="0" HorizontalAlignment="Center">
                <Ellipse Width="24" Height="24" Stroke="#E65100" StrokeThickness="2.5" HorizontalAlignment="Center"/>
                <TextBlock Text="RESTROPOS" Foreground="#A0AEC0" LetterSpacing="4" FontSize="13" Margin="0,10,0,0" HorizontalAlignment="Center" FontWeight="SemiBold"/>
            </StackPanel>

            <StackPanel Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center" Orientation="Horizontal">
                <TextBlock Text="18" FontSize="84" Foreground="#1A202C" FontWeight="Bold"/>
                <TextBlock Text=":" FontSize="84" Foreground="#E65100" FontWeight="Bold" Margin="6,0"/>
                <TextBlock Text="45" FontSize="84" Foreground="#1A202C" FontWeight="Bold"/>
                <TextBlock Text=":" FontSize="84" Foreground="#E65100" FontWeight="Bold" Margin="6,0"/>
                <TextBlock Text="45" FontSize="84" Foreground="#CBD5E0" FontWeight="Bold"/>
            </StackPanel>

            <StackPanel Grid.Row="2" HorizontalAlignment="Center" Spacing="16" Margin="0,0,0,20">
                <TextBlock Text="SÁBADO, 4 JUL 2026" Foreground="#718096" FontSize="14" HorizontalAlignment="Center" FontWeight="Medium"/>
                
                <Border Background="#E6F4EA" CornerRadius="16" Padding="18,7" HorizontalAlignment="Center">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Ellipse Width="7" Height="7" Fill="#137333" VerticalAlignment="Center"/>
                        <TextBlock Text="Servidor conectado de forma segura" Foreground="#137333" FontSize="12" FontWeight="Medium" VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Grid>

        <StackPanel Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="28">
            
            <StackPanel Spacing="12" HorizontalAlignment="Center">
                <Border Background="#FBE9E7" Width="52" Height="52" CornerRadius="12" HorizontalAlignment="Center">
                    <Canvas Width="16" Height="16" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,-2,0,0">
                        <Rectangle Width="14" Height="10" Canvas.Left="1" Canvas.Top="6" Fill="#E65100" RadiusX="1.5" RadiusY="1.5"/>
                        <Ellipse Width="10" Height="10" Canvas.Left="3" Canvas.Top="1" Stroke="#E65100" StrokeThickness="2"/>
                    </Canvas>
                </Border>
                <TextBlock Text="Acceso Express" Foreground="#1A202C" FontSize="22" FontWeight="Bold" HorizontalAlignment="Center"/>
                <TextBlock Text="Ingresa tu PIN de 4 dígitos" Foreground="#718096" FontSize="13" HorizontalAlignment="Center"/>
            </StackPanel>

            <Grid HorizontalAlignment="Center">
                <TextBox Text="{Binding PinCode}" PasswordChar="●" IsReadOnly="True" Focusable="False"
                         FontSize="24" Foreground="#4A5568" LetterSpacing="14" Background="Transparent" 
                         BorderThickness="0" TextBlock.TextAlignment="Center" Width="200"/>
            </Grid>

            <Grid Width="280" Height="320"
                  ColumnDefinitions="*, *, *"
                  RowDefinitions="*, *, *, *"
                  RowSpacing="12" ColumnSpacing="12">

                <Button Grid.Row="0" Grid.Column="0" Content="1" Classes="KeypadBtn" Command="{Binding AddDigitCommand}" CommandParameter="1"/>
                <Button Grid.Row="0" Grid.Column="1" Content="2" Classes="KeypadBtn" Command="{Binding AddDigitCommand}" CommandParameter="2"/>
                <Button Grid.Row="0" Grid.Column="2" Content="3" Classes="KeypadBtn" Command="{Binding AddDigitCommand}" CommandParameter="3"/>

                <Button Grid.Row="1" Grid.Column="0" Content="4" Classes="KeypadBtn" Command="{Binding AddDigitCommand}" CommandParameter="4"/>
                <Button Grid.Row="1" Grid.Column="1" Content="5" Classes="KeypadBtn" Command="{Binding AddDigitCommand}" CommandParameter="5"/>
                <Button Grid.Row="1" Grid.Column="2" Content="6" Classes="KeypadBtn" Command="{Binding AddDigitCommand}" CommandParameter="6"/>

                <Button Grid.Row="2" Grid.Column="0" Content="7" Classes="KeypadBtn" Command="{Binding AddDigitCommand}" CommandParameter="7"/>
                <Button Grid.Row="2" Grid.Column="1" Content="8" Classes="KeypadBtn" Command="{Binding AddDigitCommand}" CommandParameter="8"/>
                <Button Grid.Row="2" Grid.Column="2" Content="9" Classes="KeypadBtn" Command="{Binding AddDigitCommand}" CommandParameter="9"/>

                <Button Grid.Row="3" Grid.Column="0" Classes="KeypadBtn" Command="{Binding DeleteDigitCommand}">
                    <Path Data="M10,19 L2,12 L10,5 L22,5 L22,19 Z M12,8 L18,14 M18,8 L12,14" Stroke="#4A5568" StrokeThickness="2" Width="18" Height="14" Stretch="Fill"/>
                </Button>
                <Button Grid.Row="3" Grid.Column="1" Content="0" Classes="KeypadBtn" Command="{Binding AddDigitCommand}" CommandParameter="0"/>
                
                <Button Grid.Row="3" Grid.Column="2" Classes="KeypadBtn" Background="#E6F4EA" Command="{Binding LoginCommand}">
                    <Path Data="M5,12 L19,12 M12,5 L19,12 L12,19" Stroke="#137333" StrokeThickness="2.5" Width="16" Height="16" Stretch="Fill"/>
                </Button>
            </Grid>

            <TextBlock Text="{Binding ErrorMessage}" Foreground="#D32F2F" FontSize="13" FontWeight="Medium"
                       HorizontalAlignment="Center" Margin="0,2" 
                       IsVisible="{Binding ErrorMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>

            <TextBlock Text="La sesión se cerrará automáticamente tras 5 min. de inactividad." 
                       Foreground="#A0AEC0" FontSize="11" HorizontalAlignment="Center"/>
        </StackPanel>

        <Button Grid.Column="1" Width="44" Height="44" CornerRadius="22" Background="#E65100"
                HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="30">
            <TextBlock Text="?" Foreground="White" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="16"/>
        </Button>
        
    </Grid>
</UserControl>